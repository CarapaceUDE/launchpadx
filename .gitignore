# Local config and secrets
config.json
*.local.json
*.local.toml
.env
.env.*
!.env.example

# Rust build output
/target/

# Node modules
node_modules/
web/node_modules/

# Build output
web/dist/

# Playwright artifacts
web/playwright-report/
web/test-results/
web/blob-report/
web/e2e/fixtures/backups/

# Temporary workspace data
/.tmp/
/tmp/

# Local-only release automation (not shared)
scripts/local/

# Local/session artifacts (not part of the app)
agent-tools/
codex-launchpad/
codex-launchpad-src/
mcps/
terminals/

# Runtime state written during local Codex runs
.codex.pid

# WebView2 / Edge profiles (cookies, cache, session storage)
*.WebView2/
**/EBWebView/

# Local release/download staging at repo root (user paths, GH run artifacts)
/release/
/artifacts/

# Logs and diagnostics
*.log
*.trace
*.jsonl

# Compiler probes accidentally emitted at the repository root
/*.o
/*.pdb
/*_probe*
/0

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
